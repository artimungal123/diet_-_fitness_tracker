<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Posts</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
    <h1>Quora Posts</h1>
    <% for(post of posts){ %>
        <div>
            <h2>ID : <%= post.id %></h2>
            <h2>@<%= post.username %></h2>
            <h3><%= post.content %></h3>
            <br>
            <p><button><a href="/posts/<%= post.id %>"> View </a></button> &nbsp; &nbsp; &nbsp;&nbsp; <button><a href="/posts/destroy/<%= post.id %>"> Delete </a></button> &nbsp; &nbsp; &nbsp;&nbsp; <button><a href="posts/<%= post.id %>/edit">Edit</a></button></p>
            <br>
        </div>
    <% } %>
    <br><br>
    <button><a href="/posts/new">Create a Post</a></button> 
</body>
</html>